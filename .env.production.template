# Production Environment Template for Karsignal.ir
# Copy to .env and fill all values

# ============================================
# REQUIRED - Change all these values
# ============================================

# App
NODE_ENV=production
APP_PORT=3001
APP_URL=https://karsignal.ir
FRONTEND_URL=https://karsignal.ir
ADMIN_URL=https://admin.karsignal.ir
NEXT_PUBLIC_ADMIN_URL=https://admin.karsignal.ir

# Database
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@postgres:5432/career_platform
DATABASE_SHADOW_URL=postgresql://postgres:YOUR_DB_PASSWORD@postgres:5432/career_platform_shadow

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379

# Elasticsearch
ELASTICSEARCH_NODE=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=YOUR_ELASTIC_PASSWORD

# JWT - Generate with: openssl rand -base64 48
JWT_SECRET=YOUR_JWT_SECRET_HERE
JWT_REFRESH_SECRET=YOUR_JWT_REFRESH_SECRET_HERE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY  # 32 chars hex
ANONYMIZATION_SALT=YOUR_ANONYMIZATION_SALT  # Never change after launch!

# S3 / MinIO
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=YOUR_MINIO_USER
S3_SECRET_KEY=YOUR_MINIO_PASSWORD
S3_BUCKET_NAME=career-platform
S3_REGION=us-east-1
S3_PUBLIC_URL=https://karsignal.ir/files

# ============================================
# AI & External Services
# ============================================

# OpenAI (REQUIRED for AI features)
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY

# SMTP Email (for OTP, notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Karsignal <noreply@karsignal.ir>

# ============================================
# Optional Configs
# ============================================

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100
AUTH_RATE_LIMIT_TTL=900
AUTH_RATE_LIMIT_LIMIT=5

# Analytics
NEXT_PUBLIC_GA_ID=

# Kavenegar (برای ارسال SMS - اختیاری)
KAVENEGAR_API_KEY=

# Cloudflare Turnstile (bot protection)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ============================================
# Development Only - Keep Defaults
# ============================================

# Debug
LOG_LEVEL=info
DEBUG=false

# CORS
CORS_ORIGIN=https://karsignal.ir,https://admin.karsignal.ir