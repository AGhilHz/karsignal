# ============================================
# Career Transparency Platform - Environment
# ============================================

# App
NODE_ENV=development
APP_PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/career_platform
DATABASE_SHADOW_URL=postgresql://postgres:password@localhost:5432/career_platform_shadow

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword
REDIS_URL=redis://:redispassword@localhost:6379

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=elasticpassword

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (for anonymous content separation)
ENCRYPTION_KEY=32-char-hex-encryption-key-here!!
ANONYMIZATION_SALT=random-salt-for-anonymization-here

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=career-platform
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/career-platform

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# SMS (Kavenegar for Iranian market)
KAVENEGAR_API_KEY=your-kavenegar-api-key
KAVENEGAR_SENDER=10008663

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourplatform.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Career Platform <noreply@yourplatform.com>"

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Admin
ADMIN_EMAIL=admin@yourplatform.com
ADMIN_PASSWORD=change-this-in-production

# Cloudflare
CLOUDFLARE_TURNSTILE_SECRET=your-turnstile-secret
CLOUDFLARE_TURNSTILE_SITE_KEY=your-turnstile-site-key
